{
  "compilerOptions": {
    "target": "ES2024",
    "module": "ESNext",
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "outDir": "dist",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "strict": true,
    "paths": {
      "@irdashies/storybook": ["./.storybook"],
      "@irdashies/utils/*": ["./src/frontend/utils/*"],
      "@irdashies/context": ["./src/frontend/context"],
      "@irdashies/domain/*": ["./src/frontend/domain/*"],
      "@irdashies/types": ["./src/types"],
      "@irdashies/shared": ["./src/shared"]
    },
    "types": ["node", "vite/client", "w3c-web-hid"]
  },
  "include": ["src", "site/src", "tools", "vitest.setup.ts"]
}
